                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Label>
                                <Label text="Agenda: " GridPane.rowIndex="3">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Label>
                                <Label text="Desconto: " GridPane.rowIndex="4">
