<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>

<AnchorPane prefHeight="350.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifsc.fln.controller.FXMLAnchorPaneCadastroClienteDialogController">
    <children>
        <GridPane layoutX="25.0" layoutY="24.0" prefHeight="250.0" prefWidth="400.0" AnchorPane.leftAnchor="25.0" AnchorPane.rightAnchor="25.0" AnchorPane.topAnchor="20.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="10.0" prefWidth="120.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="280.0" minWidth="10.0" prefWidth="280.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Tipo de Cliente:" />
                <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="15.0" GridPane.columnIndex="1">
                    <children>
                        <RadioButton fx:id="rbPessoaFisica" mnemonicParsing="false" selected="true" text="Pessoa Física">
                            <toggleGroup>
                                <ToggleGroup fx:id="tgTipo" />
                            </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="rbPessoaJuridica" mnemonicParsing="false" text="Pessoa Jurídica" toggleGroup="$tgTipo" />
                    </children>
                </HBox>

                <Label text="Nome:" GridPane.rowIndex="1" />
                <TextField fx:id="tfNome" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Celular:" GridPane.rowIndex="2" />
                <TextField fx:id="tfCelular" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Email:" GridPane.rowIndex="3" />
                <TextField fx:id="tfEmail" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="CPF:" GridPane.rowIndex="4" />
                <TextField fx:id="tfCpf" promptText="Apenas para PF" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label text="Nascimento:" GridPane.rowIndex="5" />
                <DatePicker fx:id="dpDataNascimento" prefHeight="25.0" prefWidth="280.0" promptText="Apenas para PF" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <Label text="CNPJ:" GridPane.rowIndex="6" />
                <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="6" alignment="CENTER_LEFT">
                    <children>
                        <TextField fx:id="tfCnpj" disable="true" prefWidth="135.0" promptText="Apenas para PJ" />
                        <Label text="I.E.:" />
                        <TextField fx:id="tfInscricaoEstadual" disable="true" prefWidth="105.0" promptText="I.E." />
                    </children>
                </HBox>
            </children>
        </GridPane>
        <HBox layoutX="260.0" layoutY="300.0" spacing="10.0" AnchorPane.bottomAnchor="15.0" AnchorPane.rightAnchor="25.0">
            <children>
                <Button fx:id="btConfirmar" mnemonicParsing="false" onAction="#handleBtConfirmar" prefWidth="80.0" text="Confirmar" />
                <Button fx:id="btCancelar" mnemonicParsing="false" onAction="#handleBtCancelar" prefWidth="80.0" text="Cancelar" />
            </children>
        </HBox>
    </children>
</AnchorPane>